<Window x:Class="POSDesktopSystem.Presentation.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POSDesktopSystem.Presentation.Views.Auth"
        xmlns:vm="clr-namespace:POSDesktopSystem.Presentation.ViewModels.Auth"
        xmlns:beh="clr-namespace:POSDesktopSystem.Presentation.Behaviors"
        xmlns:conv="clr-namespace:POSDesktopSystem.Presentation.Converters"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Smart Inventory POS - Login" 
        WindowState="Maximized"
        WindowStyle="None"
        Background="{DynamicResource PrimaryBackgroundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Side: Login Form -->
        <Border Grid.Column="0" Background="{DynamicResource PrimaryBackgroundColor}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <TextBlock Text="Welcome Back"
                           FontSize="32"
                           FontWeight="ExtraBold"
                           HorizontalAlignment="Left"
                           Foreground="{DynamicResource AccentColor}"
                           Margin="0 0 0 10"/>
                
                <TextBlock Text="Please login to your account to continue"
                           FontSize="16"
                           Foreground="{DynamicResource SecondaryTextColor}"
                           Margin="0 0 0 40"/>

                <TextBlock Text="Username"
                           Style="{DynamicResource LabelStyle}"
                           Margin="0 0 0 8"/>
                <TextBox Style="{DynamicResource InputTextBoxStyle}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 0 0 20"
                         Height="45"/>

                <TextBlock Text="Password"
                           Style="{DynamicResource LabelStyle}"
                           Margin="0 0 0 8"/>
                
                <Grid Margin="0 0 0 30">
                    <PasswordBox x:Name="PassBox"
                                 Style="{DynamicResource InputPasswordBoxStyle}"
                                 PasswordChanged="PassBox_PasswordChanged"
                                 Height="45"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVis}}"/>
                    
                    <TextBox x:Name="PassText"
                             Style="{DynamicResource InputTextBoxStyle}"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Height="45"
                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVis}}"/>

                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0 0 15 0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            Cursor="Hand">
                        <TextBlock FontSize="18">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="👁️" />
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                            <Setter Property="Text" Value="🙈" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource ErrorColor}"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Margin="0 -15 0 20"/>

                <Button Content="LOGIN"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Height="50"
                        FontSize="16"
                        FontWeight="Bold"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolToVis}}"
                        Command="{Binding LoginCommand}"/>
                
                <Button Content="Exit Application"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Margin="0 15 0 0"
                        Height="45"
                        Click="ExitButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Right Side: Brand/Image Area -->
        <Border Grid.Column="1" Background="{DynamicResource AccentColor}" CornerRadius="0">
            <Grid>
                <!-- Pattern Overlay -->
                <Canvas Opacity="0.1">
                    <!-- Just some decorative elements since we don't have an image file yet -->
                    <Ellipse Fill="White" Width="300" Height="300" Canvas.Left="-50" Canvas.Top="-50"/>
                    <Ellipse Fill="White" Width="200" Height="200" Canvas.Right="-50" Canvas.Bottom="-50"/>
                </Canvas>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">
                    <TextBlock Text="Smart Inventory" 
                               FontSize="48" 
                               FontWeight="Black" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="POS DESKTOP SYSTEM" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="White" 
                               Opacity="0.8"
                               HorizontalAlignment="Center"
                               Margin="0 5 0 30"/>
                    
                    <Border Background="White" Height="4" Width="80" HorizontalAlignment="Center" CornerRadius="2" Margin="0 0 0 30"/>
                    
                    <TextBlock Text="Streamline your sales and inventory management with our modern, high-performance point-of-sale solution." 
                               FontSize="18" 
                               Foreground="White" 
                               TextWrapping="Wrap" 
                               TextAlignment="Center"
                               LineHeight="26"
                               MaxWidth="400"/>
                </StackPanel>
                
                <TextBlock Text="v1.0.0" 
                           Foreground="White" 
                           Opacity="0.5" 
                           VerticalAlignment="Bottom" 
                           HorizontalAlignment="Right" 
                           Margin="20"/>
            </Grid>
        </Border>
    </Grid>
</Window>
