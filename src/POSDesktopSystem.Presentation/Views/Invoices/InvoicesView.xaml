<UserControl x:Class="POSDesktopSystem.Presentation.Views.Invoices.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POSDesktopSystem.Presentation.Views.Invoices"
             xmlns:vm="clr-namespace:POSDesktopSystem.Presentation.ViewModels.Invoices"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0 0 0 20">
            <StackPanel>
                <TextBlock Text="Invoice History"
                           Style="{DynamicResource Heading1}"
                           Foreground="{DynamicResource AccentColor}"/>
                <TextBlock Text="View and manage all past transactions"
                           Style="{DynamicResource BodyText}"
                           Foreground="{DynamicResource SecondaryTextColor}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="REFRESH" 
                        Width="120"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Command="{Binding LoadCommand}"
                        Margin="0 0 10 0"/>
                <Button Content="VIEW DETAILS" 
                        Width="150"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding ViewDetailCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Main Content Card -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="12" 
                BorderThickness="1" 
                BorderBrush="{DynamicResource BorderColor}">
            <Grid>
                <DataGrid Style="{DynamicResource BaseDataGridStyle}"
                          ItemsSource="{Binding Invoices}"
                          SelectedItem="{Binding SelectedInvoice}"
                          BorderThickness="0"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="INVOICE #" 
                                            Binding="{Binding InvoiceNumber}" 
                                            Width="180"
                                            FontWeight="Bold"/>
                        
                        <DataGridTextColumn Header="DATE" 
                                            Binding="{Binding InvoiceDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" 
                                            Width="160"/>
                        
                        <DataGridTextColumn Header="CASHIER" 
                                            Binding="{Binding CashierName}" 
                                            Width="150"/>

                        <DataGridTextColumn Header="SUBTOTAL" 
                                            Binding="{Binding SubTotal, StringFormat='{}{0:N2}'}" 
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="DISCOUNT" 
                                            Binding="{Binding DiscountAmount, StringFormat='{}{0:N2}'}" 
                                            Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource ErrorColor}"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TOTAL" 
                                            Binding="{Binding TotalAmount, StringFormat='{}{0:N2}'}" 
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="ExtraBold"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="STATUS" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E8F5E9" CornerRadius="4" Padding="8 4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" 
                                                   Foreground="#2E7D32" 
                                                   FontSize="11" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="PAYMENT" 
                                            Binding="{Binding PaymentMethod}" 
                                            Width="120"/>

                        <DataGridTextColumn Header="PAID" 
                                            Binding="{Binding AmountPaid, StringFormat='{}{0:N2}'}" 
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="CHANGE" 
                                            Binding="{Binding Change, StringFormat='{}{0:N2}'}" 
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Invoices.Count, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="No invoices found" FontSize="18" Foreground="{DynamicResource MutedTextColor}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
