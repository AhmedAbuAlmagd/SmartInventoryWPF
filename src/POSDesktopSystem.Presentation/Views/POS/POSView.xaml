<UserControl x:Class="POSDesktopSystem.Presentation.Views.POS.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POSDesktopSystem.Presentation.Views.POS"
             xmlns:vm="clr-namespace:POSDesktopSystem.Presentation.ViewModels.POS"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Product Search & Cart -->
        <Grid Grid.Column="0" Margin="0 0 15 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search Card -->
            <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0 0 0 15" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Panel.ZIndex="100">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0 0 10 0">
                        <TextBlock Text="BARCODE SCAN" Style="{DynamicResource LabelStyle}" Margin="0 0 0 8"/>
                        <TextBox Style="{DynamicResource InputTextBoxStyle}"
                                 Height="42"
                                 FontSize="16"
                                 Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Scan or type barcode..."/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="ADD"
                            Width="80"
                            Height="42"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding AddByBarcodeCommand}"
                            Margin="0 0 20 0"/>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SEARCH PRODUCTS" Style="{DynamicResource LabelStyle}" Margin="0 0 0 8"/>
                        <TextBox Style="{DynamicResource InputTextBoxStyle}"
                                 Height="42"
                                 FontSize="16"
                                 Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Search by name, category or brand..."/>
                    </StackPanel>

                    <!-- Search Results Popup-style Overlay -->
                    <Border Grid.Column="2" 
                            Background="White" 
                            Visibility="{Binding SearchResults.Count, Converter={StaticResource BoolToVis}}"
                            Margin="0 75 0 0" 
                            CornerRadius="8" 
                            BorderThickness="1" 
                            BorderBrush="{DynamicResource BorderColor}"
                            VerticalAlignment="Top"
                            MaxHeight="400"
                            Panel.ZIndex="200"
                            Effect="{DynamicResource DropShadowEffect}">
                        <Border.Resources>
                            <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="15" ShadowDepth="5" Opacity="0.2"/>
                        </Border.Resources>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource TertiaryBackgroundColor}" Padding="15 10" CornerRadius="8 8 0 0">
                                <Grid>
                                    <TextBlock Text="Search Results" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextColor}"/>
                                    <TextBlock Text="{Binding SearchResults.Count, StringFormat='{}{0} found'}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource SecondaryTextColor}"/>
                                </Grid>
                            </Border>
                            <ListBox Grid.Row="1" ItemsSource="{Binding SearchResults}" BorderThickness="0" MaxHeight="350" HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource BorderColor}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryTextColor}"/>
                                                    <TextBlock Text="{Binding Barcode}" FontSize="12" Foreground="{DynamicResource SecondaryTextColor}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:N2}'}" FontWeight="Bold" Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Right" Margin="0 0 0 5"/>
                                                    <Button Content="ADD TO CART" 
                                                            Padding="12 4" FontSize="10"
                                                            Style="{DynamicResource PrimaryButtonStyle}"
                                                            Command="{Binding DataContext.AddFromSearchCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Cart Table Card -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20 15" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource BorderColor}">
                        <Grid>
                            <TextBlock Text="Shopping Cart" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="{Binding CartItems.Count, StringFormat='{}{0} items'}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextColor}"/>
                        </Grid>
                    </Border>

                    <!-- Cart Grid -->
                    <DataGrid Grid.Row="1"
                              Style="{DynamicResource BaseDataGridStyle}"
                              ItemsSource="{Binding CartItems}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PRODUCT" Binding="{Binding ProductName}" Width="*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="PRICE" Binding="{Binding UnitPrice, StringFormat='{}{0:N2}'}" Width="100"/>
                            <DataGridTemplateColumn Header="QTY" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="-" Width="30" Height="30" 
                                                    Background="#4e6e4e"
                                                    Foreground="White"
                                                    FontSize="18" FontWeight="Bold"
                                                    Command="{Binding DataContext.DecrementQuantityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="15"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                            
                                            <TextBlock Text="{Binding Quantity}" 
                                                       Width="40" 
                                                       TextAlignment="Center" 
                                                       VerticalAlignment="Center" 
                                                       FontWeight="Bold" 
                                                       FontSize="14"/>
                                            
                                            <Button Content="+" Width="30" Height="30" 
                                                    Background="#4e6e4e"
                                                    Foreground="White"
                                                    FontSize="18" FontWeight="Bold"
                                                    Command="{Binding DataContext.IncrementQuantityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="15"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding LineTotal, StringFormat='{}{0:N2}'}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0 0 15 0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Width="30" Height="30"
                                                Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ErrorColor}"
                                                FontWeight="Bold" FontSize="16"
                                                Command="{Binding DataContext.RemoveCartItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Right Panel: Summary & Checkout -->
        <Border Grid.Column="1" Background="{DynamicResource SecondaryBackgroundColor}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Padding="20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Checkout Summary" FontSize="20" FontWeight="ExtraBold" Foreground="{DynamicResource AccentColor}" Margin="0 0 0 15"/>

                    <Border Background="White" CornerRadius="12" Padding="15" Margin="0 0 15 0" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
                        <StackPanel>
                            <Grid Margin="0 0 0 8">
                                <TextBlock Text="Sub Total" Style="{DynamicResource LabelStyle}"/>
                                <TextBlock Text="{Binding SubTotal, StringFormat='{}{0:N2}'}" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryTextColor}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0 0 0 8">
                                <TextBlock Text="Discount" Style="{DynamicResource LabelStyle}"/>
                                <TextBox Width="100" 
                                         Style="{DynamicResource InputTextBoxStyle}"
                                         HorizontalAlignment="Right"
                                         MinHeight="36"
                                         FontSize="14"
                                         Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:N2}'}"
                                         IsEnabled="{Binding IsDiscountEditable}"
                                         Tag="0.00"/>
                            </Grid>

                            <Grid Margin="0 0 0 5">
                                <TextBlock Text="Tax (14%)" Style="{DynamicResource LabelStyle}"/>
                                <TextBlock Text="{Binding TaxAmount, StringFormat='{}{0:N2}'}" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryTextColor}" FontWeight="SemiBold"/>
                            </Grid>

                            <Separator Margin="0 10" Background="{DynamicResource BorderColor}"/>

                            <Grid>
                                <TextBlock Text="TOTAL" FontSize="24" FontWeight="ExtraBold" Foreground="{DynamicResource AccentColor}"/>
                                <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2}'}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Right" Foreground="{DynamicResource AccentColor}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="PAYMENT METHOD" Margin="0 10 0 5" Style="{DynamicResource LabelStyle}"/>
                    <ComboBox Style="{DynamicResource InputComboBoxStyle}" Margin="0 0 0 15" Height="40"
                              ItemsSource="{Binding AvailablePaymentMethods}"
                              SelectedItem="{Binding SelectedPaymentMethod}"/>

                    <TextBlock Text="AMOUNT PAID" Margin="0 0 0 5" Style="{DynamicResource LabelStyle}"/>
                    <TextBox Style="{DynamicResource InputTextBoxStyle}" 
                             FontSize="22" 
                             FontWeight="ExtraBold"
                             MinHeight="45"
                             VerticalContentAlignment="Center"
                             Foreground="{DynamicResource AccentColor}"
                             Text="{Binding AmountPaid, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:N2}'}"
                             Tag="0.00"/>

                    <Grid Margin="0 10 0 20">
                        <TextBlock Text="Change" FontSize="16" Foreground="{DynamicResource SecondaryTextColor}"/>
                        <TextBlock Text="{Binding Change, StringFormat='{}{0:N2}'}" FontSize="20" HorizontalAlignment="Right" FontWeight="ExtraBold" Foreground="{DynamicResource SuccessColor}"/>
                    </Grid>

                    <Button Content="COMPLETE SALE" 
                            Height="55"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding CheckoutCommand}"
                            FontSize="18"
                            FontWeight="Black"
                            Margin="0 0 0 10"/>
                    
                    <Button Content="CLEAR CART" 
                            Height="38"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Command="{Binding ClearCartCommand}"/>
                </StackPanel>

                <!-- Loading Overlay -->
                <Border Background="#CCFFFFFF" 
                        CornerRadius="12"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="100"
                        Margin="-20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="150" Height="4" Background="{DynamicResource BorderColor}" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="PROCESSING..." Margin="0 10 0 0" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
