<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background Colors -->
    <SolidColorBrush x:Key="PrimaryBackgroundColor" Color="#F0EDE6"/> <!-- Beige background -->
    <SolidColorBrush x:Key="SecondaryBackgroundColor" Color="#FAF8F4"/> <!-- Cream surfaces -->
    <SolidColorBrush x:Key="TertiaryBackgroundColor" Color="#F5F3ED"/> <!-- Slightly darker cream for UI elements -->

    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextColor" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SecondaryTextColor" Color="#5C5C5C"/>
    <SolidColorBrush x:Key="MutedTextColor" Color="#8E8E8E"/>

    <!-- Accent Colors -->
    <SolidColorBrush x:Key="AccentColor" Color="#4E6E4E"/> <!-- Sage green accents -->
    <SolidColorBrush x:Key="AccentHoverColor" Color="#3E583E"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#4E6E4E"/> <!-- Using sage for success too -->
    <SolidColorBrush x:Key="ErrorColor" Color="#C0392B"/>
    <SolidColorBrush x:Key="WarningColor" Color="#D35400"/>

    <!-- Border -->
    <SolidColorBrush x:Key="BorderColor" Color="#D1CFC8"/>

    <!-- Button Colors -->
    <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#4E6E4E"/> <!-- Sage green -->
    <SolidColorBrush x:Key="PrimaryButtonForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryButtonBackground" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SecondaryButtonForeground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="DangerButtonBackground" Color="#E74C3C"/>
    <SolidColorBrush x:Key="DangerButtonForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NavButtonBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="NavButtonForeground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="NavButtonHoverBackground" Color="#EBE8E0"/>

    <!-- Input Colors -->
    <SolidColorBrush x:Key="InputBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputForeground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="InputBorder" Color="#D1CFC8"/>
    <SolidColorBrush x:Key="InputFocusBorder" Color="#4E6E4E"/>

    <!-- DataGrid Colors -->
    <SolidColorBrush x:Key="DataGridBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DataGridHeaderBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="DataGridRowHover" Color="#F8F6F0"/>
    <SolidColorBrush x:Key="DataGridRowSelected" Color="#4E6E4E"/>
    <SolidColorBrush x:Key="DataGridRowSelectedForeground" Color="#FFFFFF"/>

</ResourceDictionary>
