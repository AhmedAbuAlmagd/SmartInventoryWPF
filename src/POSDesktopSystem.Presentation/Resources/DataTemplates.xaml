<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm_pos="clr-namespace:POSDesktopSystem.Presentation.ViewModels.POS"
                    xmlns:v_pos="clr-namespace:POSDesktopSystem.Presentation.Views.POS"
                    xmlns:vm_products="clr-namespace:POSDesktopSystem.Presentation.ViewModels.Products"
                    xmlns:v_products="clr-namespace:POSDesktopSystem.Presentation.Views.Products"
                    xmlns:vm_invoices="clr-namespace:POSDesktopSystem.Presentation.ViewModels.Invoices"
                    xmlns:v_invoices="clr-namespace:POSDesktopSystem.Presentation.Views.Invoices">

    <DataTemplate DataType="{x:Type vm_pos:PosViewModel}">
        <v_pos:POSView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm_products:ProductsViewModel}">
        <v_products:ProductsView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm_invoices:InvoicesViewModel}">
        <v_invoices:InvoicesView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm_invoices:InvoiceDetailViewModel}">
        <v_invoices:InvoiceDetailView/>
    </DataTemplate>

</ResourceDictionary>
